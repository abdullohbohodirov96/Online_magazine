datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  STORE_OWNER
  STORE_ADMIN
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  NEW
  ACCEPTED
  ASSEMBLING
  DELIVERING
  COMPLETED
  CANCELLED
}

model User {
  id           String      @id @default(cuid())
  phone        String      @unique
  name         String?
  role         Role        @default(CUSTOMER)
  passwordHash String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  cartItems  CartItem[]
  orders     Order[]
  telegramUser TelegramUser?
  storeUsers StoreUser[]
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  storeId   String?
}

model Store {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  legalName         String?
  description       String?
  logoUrl           String?
  faviconUrl        String?
  bannerUrl         String?
  primaryColor      String   @default("#10b981")
  secondaryColor    String?
  accentColor       String?
  textColor         String?
  backgroundColor   String?
  phone             String?
  supportPhone      String?
  telegramUsername  String?
  facebookUrl       String?
  youtubeUrl        String?
  phones            String?
  socialsJson       String?
  bannerTitle       String?
  bannerSubtitle    String?
  visits            Int      @default(0)
  branches          Branch[]
  instagramUsername String?
  email             String?
  address           String?
  latitude          Float?
  longitude         Float?
  yandexMapLink     String?
  currency          String   @default("UZS")
  language          String   @default("ru")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products            Product[]
  categories          Category[]
  orders              Order[]
  externalProducts    ExternalProduct[]
  integrationSettings IntegrationSettings?
  telegramSettings    TelegramSettings?
  smsSettings         SMSSettings?
  storeUsers          StoreUser[]
  storeDomains        StoreDomain[]
  cartItems           CartItem[]
  telegramUsers       TelegramUser[]
}

model StoreDomain {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  domain    String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreUser {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // STORE_OWNER, STORE_ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
}

model SMSSettings {
  id            String   @id @default(cuid())
  storeId       String   @unique
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider      String   @default("mock")
  eskizEmail    String?
  eskizPassword String?
  eskizFrom     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String
  image     String?
  parentId  String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToCategory")
  products  Product[]

  storeId   String
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
}

model Product {
  id                String      @id @default(cuid())
  name              String
  slug              String
  barcode           String?
  nomenclatureCode  String?
  description       String?
  price             Float
  oldPrice          Float?
  stock             Float       @default(0)
  unit              String      @default("шт")
  image             String?
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id])
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  cartItems         CartItem[]
  orderItems        OrderItem[]
  
  externalProductId String?
  source            String      @default("manual")
  syncPrice         Boolean     @default(true)
  syncStock         Boolean     @default(true)

  storeId           String
  store             Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@unique([storeId, barcode])
  @@unique([storeId, nomenclatureCode])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                String      @id @default(cuid())
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  customerName      String
  phone             String
  address           String
  comment           String?
  totalAmount       Float
  status            OrderStatus @default(NEW)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
  telegramUserId    String?
  source            String      @default("web")
  telegramChatId    String?
  addressComment    String?
  latitude          Float?
  longitude         Float?
  yandexAddress     String?
  deliveryEntrance  String?
  deliveryFloor     String?
  deliveryApartment String?
  deliveryIntercom  String?

  storeId           String
  store             Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  price       Float
  quantity    Float
  total       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntegrationLog {
  id        String   @id @default(cuid())
  type      String
  status    String
  message   String
  createdAt DateTime @default(now())
}

model IntegrationSettings {
  id                    String    @id @default(cuid())
  integrationEnabled    Boolean   @default(false)
  integrationMode       String    @default("disabled")
  integrationApiUrl     String?
  integrationApiKey     String?
  autoUpdatePrices      Boolean   @default(true)
  autoUpdateStock       Boolean   @default(true)
  syncIntervalMinutes   Int       @default(5)
  lastSyncAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  providerName          String?
  providerType          String    @default("manual_json")
  authType              String    @default("none")
  requestMethod         String    @default("GET")
  productsEndpoint      String?
  ordersEndpoint        String?
  priceFieldMapping     Json?
  stockFieldMapping     Json?
  fieldMapping          Json?
  isConnected           Boolean   @default(false)
  lastConnectionCheckAt DateTime?
  syncStatus            String?
  syncErrorMessage      String?

  storeId               String    @unique
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ExternalProduct {
  id               String   @id @default(cuid())
  barcode          String?
  nomenclatureCode String?
  name             String
  price            Float
  stock            Float
  unit             String
  categoryName     String?
  rawData          Json?
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, barcode])
  @@unique([storeId, nomenclatureCode])
}

model TelegramUser {
  id         String   @id @default(cuid())
  telegramId String   @unique
  userId     String?  @unique
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?
  authDate   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId    String?
  store      Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
}

model TelegramSettings {
  id                  String   @id @default(cuid())
  botToken            String?
  adminChatId         String?
  notificationsEnabled Boolean  @default(true)
  botUsername         String?
  miniAppUrl          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  storeId             String   @unique
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}


model Branch {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  address   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
